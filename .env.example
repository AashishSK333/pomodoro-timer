# Backend — SQLite database path (default: sessions.db next to main.py)
DB_PATH=backend/sessions.db

# Backend — comma-separated list of allowed CORS origins
ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# Notion integration — used by Claude MCP sync only, NOT read by the backend
NOTION_DATABASE_ID=your_notion_database_id_here
NOTION_DATASOURCE_ID=your_notion_datasource_id_here
